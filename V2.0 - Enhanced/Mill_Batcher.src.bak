program Mill_Batcher;

#include test-import.iri  

  ----------------------------------------------------------------------------
  -- Begin constants and aliases definitions here.
  
  g_csProgName : constant string := "Mill_Batcher";  
  g_csVersion : constant string := "03.06.15";
 
  -- End of constants and aliases.
  ----------------------------------------------------------------------------
  

  ----------------------------------------------------------------------------
  -- Begin user created types (enumerations, records, arrays) definitions.
  type StringArray is array[50] of string;
  type RealArray is array[50] of real;
  type IntArray is array[50] of integer;
  

  -- End of user created types (enumerations, records, arrays).
  ----------------------------------------------------------------------------



  ----------------------------------------------------------------------------
  -- Start global variables definitions here.  Don't forget to initialize 
  -- them in the system startup event handler.
  
  g_StartingWeight : real;      -- Records amount tore off when starting batch for display purposes.
  g_srcResult    : SysCode;
  g_Bit:    integer  :=0;   -- Keeps track of the Estop status.  0=Good, 1=Stop   
  g_Count : integer;    -- Currently Selected Ration from knob
  g_Key : integer; 
  g_Level : integer :=0;
  g_MaxRations : integer :=50;
  g_MaxIngredients  : integer :=26; 
  g_SubLevel : integer :=0;
  g_BitStatus : integer;
  g_CurrentRation :  string := "";  
  g_CurIngredient : string;
  g_RecordCount : integer;    
  g_CurrentTarget : integer;
  g_CurrentSp : integer;
  g_OpenOutput : integer;
  g_IngredNames : stringarray;  
  g_SPValues : realarray;   
  g_SpPreact : realarray;  
  g_SpMin : realarray;                -- Stores the early cutoff value for an ingredient in a ration
  g_SpMax : realarray;
  g_SpOut : IntArray;
  g_Load :  integer;
  g_WaitSp : integer;  -- Used to bypass calculations and flag errors after ingredient has dispensed.
  g_CurSpValue : real;
  g_FillStep    : integer;  -- Used to store whether ingredients are filled with fast / slow or just a fast fill method
  g_PageStart   : integer;
  g_ScaleRationTargetWeight : real;   -- Stores the Total weight to be dispensed into scale for a ration
    
  -- End of global variables.  
  ----------------------------------------------------------------------------


  ----------------------------------------------------------------------------
  -- Start functions and procedures definitions here.    
function GetFactor : real;
--Declaration Section
Factor : real;
R_Names : R_NamesDatabase;
begin
    R_Names.Name:=g_CurrentRation;
    R_Names.FindFirst(R_Names_Name);
    -- WriteLn(2,"Getting Factor g_CurrentTarget = ",RealToString(g_CurrentTarget,0,3));
    -- WriteLn(2,"Getting Factor R_Names.Total = ",RealToString(R_Names.Total,0,3));
    if R_Names.Total > 0 then
       Factor:=g_CurrentTarget/R_Names.Total;
    else
       Factor :=1;    
    end if;


    return(Factor);

end;


  
  
procedure UnloadToTruck;
--Declaration Section

begin
      SetLabelText(Lbl3S2,"");
      SetLabelText(Lbl4S2,"Unloading");
      SetLabelText(Lbl5S2,"Tank");
      --ResetBatch;
      
      SetSoftkeyText(1,"Cancel");
      SetSoftkeyText(2,"");
      SetSoftkeyText(3,"Pause");
      SetSoftkeyText(4,"");
      SetSoftkeyText(5,"");   
      --DisableSP(99);                   
    return;

end;



procedure TareScale;
--Declaration Section
lCount : integer;
lindex : integer;             
Net : real ;


begin 
     
     WriteLn(2,"Tare Scale Called");
     lCount:=0;    -- used as a loop counter.  After 20 failures to Tare Scale user is notified
     
     while lCount<=100
     loop
       
       lCount:=lCount+1;   
       if AcquireTare(Scale1)=SysOk then
       
         GetNet(scale1,Primary,Net);
         if Net<5 then
          
           WriteLn(2,"Aquire Tare Good - Net within 5 of Zero  Net = "+RealToString(Net,0,0));
           SetLabelText(Lbl3S2,"");
           exit;
         
         else
         
           WriteLn(2,"Aquire Tare Good - Net NOT WITHIN 5 of Zero  Net = "+RealToString(Net,0,0));
           
         end if;
       
       else                                                             
       
         WriteLn(2,"Aquire Tare Fail - Current Net = "+RealToString(Net,0,0));
         
       end if;
       SetLabelText(Lbl3S2,"Taring Scale..."+IntegerToString(lCount,0));          
       
       -- Pause to give scale a chance to settle down
       for lindex := 1 to 10000
       loop
       
         if lindex=5000 then  -- Check scale at half way mark.
           if AcquireTare(Scale1)=SysOk then
             exit;
           end if;
         end if;
        
       end loop;  
       
     end loop;            
     if lCount>=99 then
      WriteLn(2,"Attempt to Tare Failed.  Batch should be paused"); 
      g_SubLevel:=1;                
      PauseBatch;
         
     end if;
   return;

end;

  
procedure StoreLoad(Cancelled : integer);
--Declaration Section
LoadDb : LoadsDatabase;
RationIngredDB : R_IngredDatabase;
Net : real;
Factor : real;
begin         
    Factor:=GetFactor;
    GetNet(Scale1,Primary,Net);
    RationIngredDB.GetFirst;
    loop
      if RationIngredDB.Ration=g_CurrentRation and RationIngredDB.Ingred=g_CurIngredient then
        exit;
      end if;
      if RationIngredDB.GetNext<>SysOk then 
        exit;
      end if;          
    end loop;
    LoadDb.Date:=SystemTime;
    LoadDB.Load:=g_Load;     
    LoadDB.Ingred := g_CurIngredient;
    LoadDB.Target:=RationIngredDB.Target*Factor;

    LoadDB.Actual:=Net;
    LoadDB.Ration:=g_CurrentRation;
    LoadDB.Sent:=0;    
    if Cancelled=1 then
       LoadDB.Status:=3;
    elsif Net < RationIngredDB.Target-RationIngredDB.Min then
       LoadDB.Status:=1;
    elsif Net > RationIngredDB.Target+RationIngredDB.Max then
       LoadDB.Status:=2;
    else 
       LoadDB.Status:=0;
    end if;
    
    LoadDB.Add;
    
        
    return;

end;



procedure EnableHandelers;
--Declaration Section

begin        
    EnableHandler(Numerickeypressed);
    EnableHandler(Navupkeypressed);
    EnableHandler(Navdownkeypressed);
    



    return;

end;
  

procedure DisableHandlers;
--Declaration Section

begin        
    DisableHandler(Numerickeypressed);
    DisableHandler(Navupkeypressed);
    DisableHandler(Navdownkeypressed);
    



    return;

end;
  
  
  procedure InitializeDatabase;
--Declaration Section
Setup : SetupDatabase;
ingred : IngredDatabase;
index : integer;
begin

    WriteLn(2,"Init Database Section");
    if Setup.GetFirst<>SysOk then --Cant Find the Setup Record so Make some Default Values
       WriteLn(2,"Setup - No Records...initializing");
       Setup.MinLoad:=500;
       Setup.MaxLoad:=31000;
       Setup.FillStep:=1;
       Setup.Update;
    else
        WriteLn(2,"Setup - Records found...");
        g_FillStep:=Setup.FillStep;
        WriteLn(2,"Fillstep= "+IntegerToString(g_FillStep,1));
    end if;   
    
    if ingred.GetFirst<>SysOk then
       WriteLn(2,"Ingredients - No Records...initializing");
       for index := 1 to 26
       loop
          if ingred.GetNext<>SysOk then
            ingred.Name:="";
            ingred.Low_Act:=0;
            ingred.High_Act:=0;
            if index < 17 then 
                ingred.Output:=index;
            else
                ingred.Output:=99;
            end if;
            ingred.Add;
          end if;          
       end loop;
    else
        WriteLn(2,"Ingredients - Records found...Good");   
    end if;    
    return;

end;

  
  function MakeVersionString : string; 
    
    sTemp : string;
    
  begin 
    
    sTemp := ("Ver " + g_csVersion);
      
    return sTemp;
    
  end;  
     
  procedure DisplayVersion; 
  
  begin
   
    DisplayStatus(g_csProgName + "  " + MakeVersionString);
  
  end;

