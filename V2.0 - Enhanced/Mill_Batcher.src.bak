handler Timer1Trip;--Update Display
--Declaration Section
CurrentSp : integer;
BS : BatchStatus;

begin  
    
    GetBatchStatus(BS);
    if g_Level=8 or g_Level=9 then
        
        if BS= BatchPaused and g_SubLevel=0 then
            WriteLn(2,"Batch Should be running but is paused.");
        elsif BS = BatchRunning and g_SubLevel=0 then 
            WriteLn(2,"Batch is running"); 
        elsif BS = BatchComplete and g_SubLevel=0 then
            WriteLn(2,"Batch is Complete"); 
        elsif BS = BatchStopped and g_SubLevel=0 then
            WriteLn(2,"Batch is Stopped"); 
            
        end if;
        UpdateDisplay;   

    end if;
    return;

end;


handler Timer2Trip;--Update BarGraph
--Declaration Section
Net : real;       
Gross : real;
CorrectedWeight : real;
CurrentSp : integer;              
BLevel : integer;
BLevel2 : integer;
Index   : integer;
Target  : real; 
--BS : BatchStatus;

begin   
    
    --GetBatchStatus(BS);
    -- If batch is paused and we are in batch menu and we have not manually paused the batch
    -- Start the timer to start the batch.
    --if BS= BatchPaused and g_Level=8 and g_SubLevel=0 then
        --StartTimer(1);
    --end if;
    GetGross(Scale1,Primary,gross);
    CorrectedWeight:=Gross - g_StartingWeight;
    GetCurrentSP(CurrentSp);
    if g_Level=8 then
        
        index:=((CurrentSp-3)/5)+1;
        Target:=g_SPValues[index];
              
        GetNet(Scale1,Primary,Net); 
        
        if Target > 0 then
            BLevel:=(Net/Target)*100;
            --WriteLn(2,IntegerToString(BLevel,0));
        end if;
        SetLabelText(lbl14s2,RealToString(CorrectedWeight,5,0));
        SetLabelText(lbl9s2,RealToString(g_ScaleRationTargetWeight,5,0));
                
    elsif g_Level=9 then
      
        if g_CurrentTarget>0 then
            BLevel:=(Gross/g_CurrentTarget)*100;
--            WriteLn(2,"Gross = "+RealToString(gross,4,0));
--            WriteLn(2,"gTarg = "+RealToString(g_CurrentTarget,4,0));
--            WriteLn(2,"Level = "+IntegerToString(BLevel,4));
--            
        else
            BLevel:=0;
        end if;        
    
    end if;

--  Commented Out Section is for a second Bargraph if customer wants one.
--    
--    if g_ScaleRationTargetWeight>0 then
--      
--      BLevel2:=(Gross/g_ScaleRationTargetWeight)*100;
--
--    else
--    
--      BLevel2:=0;
--    
--    end if;        

    if BLevel>100 then 
       BLevel:=100;
    end if;
--    if BLevel2>100 then 
--       BLevel2:=100;
--    end if;              
    SetBargraphLevel(Bar1S2,BLevel);
--    SetBargraphLevel(Bar2S2,BLevel2);
    return;

end;

handler Timer3Trip;  -- Batch Status Check
--Declaration Section
BS  : BatchStatus;

begin

    GetBatchStatus(BS);
    
    if BS <> BatchRunning then
    
        WriteLn(2,"Batch Not Running yet");
        StartBatch;
        StartTimer(3);
    
    else
        
        WriteLn(2,"Batch is now Running.");
        DisplayStatus("");
        g_Level:=8;           
        UpdateDisplay;
            
    end if;
    return;
    
end;

  -- End of event handlers.
  ----------------------------------------------------------------------------

   


------------------------------------------------------------------------------
-- This chunk of code is the system startup event handler.

begin
  SetTimer(1,40);
  SetTimerMode(1,TimerContinuous);
  --StartTimer(1);
  SetTimer(2,50);
  SetTimerMode(2,TimerContinuous);
  --StartTimer(2);
  SetTimer(3,100);
  SetTimerMode(3,TimerOneShot);
  
   
  -- Initialize all global variables here. 
  WriteLn(2,"Initialization Started.");
  InitializeDatabase;   
  UpdateDisplay;     
  -- Display the version number to the display.
  DisplayVersion;
   

end Mill_Batcher; 
-- This name must match the name following "program" keyword at 
-- the beginning of the program.

