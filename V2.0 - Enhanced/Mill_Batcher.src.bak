handler Sp3Trip;
--Declaration Section
state   : integer;

begin
    
    if g_SpOut[1]<17 then
        SetDigout(2,g_SpOut[1],1);
    elsif g_SpOut[1]=99 then 
        
        SetLabelText(Lbl3S2,"Hand Filling");
        SetLabelText(Lbl4S2,g_IngredNames[1]);
        SetLabelText(Lbl5S2,"Target = "+RealToString(g_SPValues[1],4,0));
        PausetheBatch;
        
    end if;
    
    
    UpdateDisplay;
    return;

end;       

