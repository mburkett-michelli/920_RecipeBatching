function RationIngredients : StringArray;
--Declaration Section
IngredName : StringArray;
RationIngredDB : R_IngredDatabase;
index : integer;
begin    
    
    for Index:= 1 to 8               
    loop
      IngredName[index]:="";         
    end loop;
    Index:=1;
   
    if RationIngredDB.GetFirst=SysOk then --Their are Ration Names In The Database
       loop
         if RationIngredDB.Ration=g_CurrentRation then
           IngredName[index]:=RationIngredDB.Ingred;
           Index:=Index+1;    
         end if;  
         if RationIngredDB.GetNext<>SysOk or index>8 then 
            exit;
         end if;   
         
       end loop;
    end if;
    return(IngredName);

end;
 

procedure UpdateDisplay;
--Declaration Section
LoadsDB : LoadsDatabase;
RationIngredDB : R_IngredDatabase;    
RationNamesDB : R_NamesDatabase;
IngredName : StringArray;
R_IngredName : StringArray;  
IngredDB : IngredDatabase;
Index : integer;
TempIngred : StringArray;
Bit : integer;
CurrentSP : integer;  
CurSpName : string;  
CurSpValue : real;
Net : real;   
Gross : real;  
Found : integer;  
Factor : real;
Min : real;
Max : real; 

Target : real;     -- Used to Calculate and display the actual target for the ingredient not cutoff amt 

begin
    if g_Level=0 then 
      ClearTare(1);
      DisableSP(50); --Unload Setpoint
      CurrentSp:=0;       
      g_CurrentSp:=0;
      SelectScreen(1);
      SetLabelText(Lbl2S1,"No Ration Selected");
      SetLabelText(lbl3S1,"Select Ration");
      SetLabelText(lbl4S1, "To Continue");
       
      SetSoftkeyText(1,"");
      SetSoftkeyText(2,"");
      SetSoftkeyText(3,"Select Ration");
      SetSoftkeyText(4,"");
      SetSoftkeyText(5,"Setup"); 
      g_CurrentTarget:=0;        
      g_SubLevel:=0;
    elsif  g_Level=2 and g_SubLevel=1 then 
      SetLabelText(lbl1S10,"**************");
      SetLabelText(lbl2S10,"Delete Ration");
      SetLabelText(lbl3S10,"");
      SetLabelText(lbl4S10,g_CurrentRation);                        
      SetLabelText(lbl5S10,"**************");
      SetSoftkeyText(1,"No");
      SetSoftkeyText(2,"");
      SetSoftkeyText(3,"");
      SetSoftkeyText(4,"");
      SetSoftkeyText(5,"Yes");      
      
      
    elsif g_Level=1 or g_Level=2 then --Select Ration Or Edit Ration
      SelectScreen(10);    
      
      if RationNamesDB.GetFirst<>SysOk then --No Ration Names In The Database
          g_Count:=0;
          SetLabelText(lbl1S10,"");
          SetLabelText(lbl2S10,"No Rations");
          SetLabelText(lbl3S10,"Created");
          SetLabelText(lbl4S10,"Add A Ration");                        
          SetLabelText(lbl5S10,"");
          SetSoftkeyText(1,"");
          if g_Level=2 then
            SetSoftkeyText(2,"Add Ration");
          else
            SetSoftkeyText(2,"");
          end if;
            
          SetSoftkeyText(3,"");
          SetSoftkeyText(4,"");
          SetSoftkeyText(5,"Cancel");
      else  
        
        RationNamesDB.GetFirst;
        index:=0;--Get the Count Of the Records
        RationNamesDB.GetFirst;
        index:=0;
        loop
          if RationNamesDB.GetNext<>SysOk then 
            exit;
          end if;
         index:=index+1;                               
        end loop;
        if g_Count>index then 
          g_Count:=0;
        elsif g_Count<0 then 
          g_Count:=index;    
        end if;        
        RationNamesDB.GetFirst;    
        g_CurrentRation:=RationNamesDB.Name; 
        if g_Count>0 then
          for index := 1 to g_Count        
          loop    
            if  RationNamesDB.GetNext <>SysOk then
              
              RationNamesDB.GetFirst; 
              g_CurrentRation:=RationNamesDB.Name; 
              g_Count:=0;
              exit;
            end if;  
            g_CurrentRation:=RationNamesDB.Name; 
          end loop ; 
        end if;    
        if g_Level=2 then
          SetLabelText(lbl1S10,"Edit Ration");
          SetLabelText(lbl4S10,"Select Ration");
          SetLabelText(lbl5S10,"Then Press Ok");
          SetSoftkeyText(1,"Delete Ration");
          if g_Count<25 then
            SetSoftkeyText(2,"Add Ration");
          else
            SetSoftkeyText(2,"");
          end if;            
          SetSoftkeyText(3,"Ok");           
          SetLabelText(lbl2S10,"Ration");
          SetLabelText(lbl3S10,g_CurrentRation);

        else     
           
          RationNamesDB.Name:=g_CurrentRation;
          RationNamesDB.FindFirst(R_Names_Name);
          if g_CurrentTarget=0 then
            g_CurrentTarget:=RationNamesDB.Total;
          end if;                               
          GetDigin(0,1,Bit);

          if Bit=0 then         
            SelectScreen(1);
            SetLabelText(lbl2S1,"Ration : "+g_CurrentRation);
            SetLabelText(lbl3S1,"Total Load Weight");
            SetLabelText(lbl4S1,IntegerToString(g_CurrentTarget,0)+" lbs");
            SetSoftkeyText(1,"Change Load Size");
            SetSoftkeyText(2,""); 
            SetSoftkeyText(3,"Start Batch");
          else
            SetLabelText(lbl2S1,"Emergency");
            SetLabelText(lbl3S1,"Stop");
            SetLabelText(lbl4S1,"Activated");
            SetSoftkeyText(1,"");
            SetSoftkeyText(2,""); 
            SetSoftkeyText(3,"");
          
          end if;  
        end if;        
       
        SetSoftkeyText(4,"");
        SetSoftkeyText(5,"Cancel");
 
      end if;               
                   
    elsif g_Level=3 then --Enter Setup
      SelectScreen(10);
      SetLabelText(Lbl1S10,"");
      SetLabelText(Lbl2S10,"");
      SetLabelText(Lbl3S10,"*** System Setup  ***");
      SetLabelText(Lbl4S10,"");
      SetLabelText(Lbl5S10,"");
      SetSoftkeyText(1,"Edit Rations");
      SetSoftkeyText(2,"Edit Ingredients");
      SetSoftkeyText(3,"Set Time");
      SetSoftkeyText(4,"");
      SetSoftkeyText(5,"Done");
      
    elsif g_Level=4 then --Edit Ingredients
      if g_Count>7 then
        g_Count:=0;
      elsif g_Count<0 then
        g_Count:=7;
      end if;                          
      SelectScreen(3); 
      for index := 0 to 7  
      loop                 
        if index=0 then
          IngredDB.GetFirst;
        else
          IngredDB.GetNext;
        end if;      
        if g_Count=index then
            --SetWidgetVisibility(Lbl11S3+index,VOn); 
            SetLabelText(Lbl11S3+index,"Selected Ingredient-->>" );     
            g_CurIngredient:=IngredDB.Name;
        else  
            SetLabelText(Lbl11S3+index,"" ); 
            --SetWidgetVisibility(Lbl11S3+index,VOff);
        end if;                         
        --SetWidgetVisibility(Lbl1S3+index,VOn);
        if IngredDB.Name="" then
            SetLabelText(Lbl1S3+index,"  (Not Setup)");
        else
            SetLabelText(Lbl1S3+index,IngredDB.Name);
        end if;
      end loop;                                     
      
      SetLabelText(Lbl10S3,"*** Ingredient Setup ***");
      SetLabelText(Lbl9S3,"Select Ingredient To Edit"); 
      SetSoftkeyText(1,"Edit Name"); 
      if g_CurIngredient="" then
        SetSoftkeyText(2,"");
        SetSoftkeyText(3,"");
      else
        SetSoftkeyText(2,"Edit High Preact");
        SetSoftkeyText(3,"Edit Low Preact");
      end if;  
      SetSoftkeyText(4,"");
      SetSoftkeyText(5,"Done");
      
    elsif g_Level=5 then   --- Add/ Edit Ingredients For Ration                     
      SelectScreen(3); 
      RationNamesDB.Name:=g_CurrentRation;
      RationNamesDB.FindFirst(R_Names_Name); 
      SetLabelText(Lbl10S3,"Edit Ration : "+g_CurrentRation);       
      SetLabelText(Lbl9S3,"Total Load Weight ="+IntegerToString(RationNamesDB.Total,0));       
      --Get a list of Rations Ingredients Matching the Ration Selected
      IngredName:=RationIngredients;
      g_RecordCount :=0;
      for index := 1 to 8  
      loop 
        if IngredName[index]<>"" then
          SetLabelText(Lbl1S3+index-1,IngredName[index]);
          g_RecordCount:=g_RecordCount+1;
          
        else
          SetLabelText(Lbl1S3+index-1,"");
        end if;
      end loop;
                                                            
      if g_Count>g_RecordCount-1 then
        g_Count:=0;
      elsif g_Count<0 then
        g_Count:=g_RecordCount-1;
      end if;  
      if g_Count<0 then
        g_Count:=0;
      end if;
      
      for index:= 0 to 7
      loop
        if index=g_Count and g_RecordCount>0 then
          SetLabelText(Lbl11S3+index,"Selected Ingredient--->>");
          g_CurIngredient:=IngredName[index+1];
        else
          SetLabelText(Lbl11S3+index,"");
        end if;
      end loop; 
      
      if g_RecordCount>0 then       
         SetSoftkeyText(1,"Delete Selected");
         SetSoftkeyText(3,"Edit Selected");
      else                       
         SetSoftkeyText(1,"");             
         SetSoftkeyText(3,"");
      end if;                 
      if g_RecordCount<8 then
        SetSoftkeyText(2,"Add Ingredient");
      else
        SetSoftkeyText(2,"");
      end if;
      SetSoftkeyText(4,"Edit Total Weight"); 
      SetSoftkeyText(5,"Done");  
    
  ---Select a ingredient to add to a ration  
    elsif g_Level=6 then
      SelectScreen(3);  
      SetLabelText(Lbl10S3,"*** Select New Ingredient ***");       
      SetLabelText(Lbl9S3,"For Ration : "+g_CurrentRation);   
      R_IngredName:=RationIngredients;
      g_RecordCount :=0;
      IngredDB.GetFirst;  
      for g_RecordCount := 1 to 8
      loop
        TempIngred[g_RecordCount]:=IngredDB.Name;
        for index := 1 to 8  
        loop
          if TempIngred[g_RecordCount]=R_IngredName[index] then
            TempIngred[g_RecordCount]:="";          
          end if;
        end loop;
        IngredDB.GetNext;
      end loop;
                  
      index:=1;
      for g_RecordCount := 1 to 8
      loop
        IngredName[g_RecordCount]:="";
        if TempIngred[g_RecordCount]<>"" then
          IngredName[index]:=TempIngred[g_RecordCount]; 
          index:=index+1;
        end if;
      end loop;
      
      g_RecordCount:=0;  
      for index := 1 to 8  
      loop 
        SetLabelText(Lbl1S3+index-1,IngredName[index]);
        if IngredName[index]<>"" then
            g_RecordCount:=g_RecordCount+1;
        end if;  
      end loop;
          
      if g_Count>g_RecordCount-1 then
        g_Count:=0;
      elsif g_Count<0 then
        g_Count:=g_RecordCount-1;
      end if;  
      if g_Count<0 then
        g_Count:=0;
      end if;
        
      for index:= 0 to 7
      loop
        if index=g_Count and g_RecordCount>0 then
          SetLabelText(Lbl11S3+index,"Selected Ingredient--->>");
          g_CurIngredient:=IngredName[index+1];
        else
          SetLabelText(Lbl11S3+index,"");                                  
        end if;
      end loop; 
      SetSoftkeyText(1,"");             
      SetSoftkeyText(2,"");      
      SetSoftkeyText(3,"Add To Ration");
      SetSoftkeyText(4,"");  
      SetSoftkeyText(5,"Cancel");   

--Edit Ration ingredients info      
    elsif g_Level=7 then
      RationIngredDB.GetFirst;
      loop
        if RationIngredDB.Ration=g_CurrentRation and RationIngredDB.Ingred=g_CurIngredient then
          exit;
        end if;  
        if  RationIngredDB.GetNext<>SysOk then
          exit;
        end if;  
      end loop; 
      SelectScreen(5);  
      RationNamesDB.Name:=g_CurrentRation;
      RationNamesDB.FindFirst(R_Names_Name);
      SetLabelText(Lbl1S5,"Edit Ingredient For Ration "+RationIngredDB.Ration);
      SetLabelText(Lbl2S5,RationIngredDB.Ingred);
      SetLabelText(Lbl9S5,"Target Weight for a "+IntegerToString(RationNamesDB.Total,0)+" lb load ");  
      SetLabelText(Lbl5S5,IntegerToString(RationIngredDB.Target,0));
      SetLabelText(Lbl6S5,IntegerToString(RationIngredDB.Min,0));
      SetLabelText(Lbl10S5,IntegerToString(RationIngredDB.Max,0));
      SetSoftkeyText(1,"Edit Target Weight");
      SetSoftkeyText(2,"Edit Cutoff Value");
      SetSoftkeyText(3,"Edit Max Value");
      SetSoftkeyText(4,"");
      SetSoftkeyText(5,"Done");

----Batching      
    elsif g_Level=8 then -- Batching has started
      GetDigin(0,1,Bit);
       if Bit=1 then --Estop has been pressed
          SetLabelText(Lbl2S2,"Emergency Stop Pressed");
          SetLabelText(Lbl3S2,"Batch Cannot Continue");
          SetLabelText(Lbl4S2,"Until Emergency Stop");
          SetLabelText(Lbl5S2,"Is Released");
          SetSoftkeyText(1,"");
          SetSoftkeyText(2,"");
          SetSoftkeyText(3,"");
          SetSoftkeyText(4,"");
          SetSoftkeyText(5,"");
          g_Level:=10; 
       else
          --Some times for some reason the system returns 101 for the current setpoint???       
          if GetCurrentSP(CurrentSp)<>SysOk then
             CurrentSp := g_CurrentSp;      
          end if;
          if CurrentSp>100 then
              WriteLn(2,"--------------------------");
              WriteLn(2,"Current Setpoint > 100  =>"+IntegerToString(CurrentSP,0));
              WriteLn(2,"--------------------------");
             CurrentSp := g_CurrentSp;
          end if;   
          if CurrentSp =1 and g_CurrentSp>1  then
              ResetBatch;
              g_Level:=9;
              SetTimerMode(1,TimerOneShot);
              SetTimer(1,50);
              StartTimer(1);    
          else
              g_CurrentSp:=CurrentSp;
              SelectScreen(2);
              SetLabelText(Lbl2S2,"Loading Ration "+g_CurrentRation);
              -- WriteLn(2,"Current Setpoint "+IntegerToString(CurrentSp,0));
              -- WriteLn(2,"g_WaitSp = "+IntegerToString(g_WaitSp,0));
              index:=((CurrentSp-3)/5)+1;
              Target:=g_SPValues[index];
                   
              if CurrentSp=1 then
                 g_WaitSp:=0;  -- Resetting ingredient finished variable
                 SetLabelText(Lbl3S2,"");
                 SetLabelText(Lbl4S2,"Checking Zero..");
                 SetLabelText(Lbl5S2,"");                     
                 SetSoftkeyText(1,"Pause Batch");
                 SetSoftkeyText(2,"");
                 SetSoftkeyText(3,"");
                 SetSoftkeyText(4,"");
                 SetSoftkeyText(5,"");
                 SetTimerMode(1,TimerOneShot);
                 SetTimer(1,50);
                 StartTimer(1);    
                       
                   
              elsif CurrentSp=3 or CurrentSp=8 or CurrentSp=13  --Fast Fill Setpoints
                 or CurrentSp=18 or CurrentSp=23 or CurrentSp=28 
                 or CurrentSp=33 or CurrentSp=38 
                 then                 
                   
                   if g_WaitSp>0 then  -- Reset Wait Setpoint to Zero if starting new Fill. 
                
                     -- WriteLn(2,"g_WaitSp set to Zero");
                     g_WaitSp:=0;
                
                   end if;
                
                   g_CurIngredient := g_IngredNames[index];
                                      
                   GetSPValue(CurrentSp+2,CurSpValue);
                   g_CurSpValue :=CurSpValue;
                   GetSPValue(CurrentSp,CurSpValue);
                   -- WriteLn(2,"Fast Filling Ingredient: "+g_CurIngredient);
                   SetLabelText(Lbl3S2,"Fast Filling");
                   SetLabelText(Lbl4S2,g_CurIngredient);
                   SetLabelText(Lbl5S2,"Target = "+RealToString(Target,4,0));
                   SetSoftkeyText(1,"Pause Batch");
                   SetSoftkeyText(2,"");
                   SetSoftkeyText(3,"");
                   SetSoftkeyText(4,"");
                   SetSoftkeyText(5,"");
                   SetTimerMode(1,TimerOneShot);
                   SetTimer(1,50);
                   StartTimer(1);    
                   
              elsif  CurrentSp=4 or CurrentSp=9 or CurrentSp=14  --Wait 5 Seconds
                 or CurrentSp=19 or CurrentSp=24 or CurrentSp=29 
                 or CurrentSp=34 or CurrentSp=39 
                 then   
                   
                   -- WriteLn(2,"Pausing 5 Seconds");
                   SetLabelText(Lbl3S2,"Slow Filling Ingredient");
                   SetLabelText(Lbl4S2,g_CurIngredient);
                   SetLabelText(Lbl5S2,"Target = "+RealToString(Target,4,0));
                   SetSoftkeyText(1,"Pause Batch");
                   SetSoftkeyText(2,"");
                   SetSoftkeyText(3,"");
                   SetSoftkeyText(4,"");
                   SetSoftkeyText(5,"");
                   
              elsif  CurrentSp=5 or CurrentSp=10 or CurrentSp=15    -- Slow Fill Engaged
                 or CurrentSp=20 or CurrentSp=25 or CurrentSp=30    
                 or CurrentSp=35 or CurrentSp=40 
                 then 
                   
                   -- WriteLn(2,"Slow Filling Ingredient: "+g_CurIngredient);
                   GetSPValue(CurrentSp,CurSpValue);
                   SetLabelText(Lbl3S2,"Slow Filling Ingredient");
                   SetLabelText(Lbl4S2,g_CurIngredient);
                   SetLabelText(Lbl5S2,"Target = "+RealToString(Target,4,0));
                   SetSoftkeyText(1,"Pause Batch");
                   SetSoftkeyText(2,"");
                   SetSoftkeyText(3,"");
                   SetSoftkeyText(4,"");
                   SetSoftkeyText(5,"");
                   
        
              elsif CurrentSp=6 or CurrentSp=11 or CurrentSp=16    -- Waits for StandStill setpoint
                 or CurrentSp=21 or CurrentSp=26 or CurrentSp=31   -- to become satisfied.
                 or CurrentSp=36 or CurrentSp=41 
                 then                                    
                   -- WriteLn(2,"Waiting for Standstill... ");
                   SetLabelText(Lbl3S2,"Checking Weight");
                   SetTimerMode(1,TimerOneShot);
                   SetTimer(1,50);
                   StartTimer(1);    
                 
                 
              elsif CurrentSp=7 or CurrentSp=12 or CurrentSp=17  -- Pause Setpoints
                 or CurrentSp=22 or CurrentSp=27 or CurrentSp=32 -- This pauses the setpoints to make sure
                 or CurrentSp=37 then                            -- They don't outdistance the code.
                 -- WriteLn(2,"We Paused The Scale at Setpoint "+IntegerToString( CurrentSp,0)); 
                 
                 if g_WaitSp<1 or g_WaitSp>1  then -- If first time or error occurred last time execute, otherwise skip
                   RationIngredDB.GetFirst;
                   loop
                      if RationIngredDB.Ration=g_CurrentRation then
                        -- WriteLn(2,"Current  g_WaitSp  => "+IntegerToString(g_WaitSp,0));
                        -- WriteLn(2,"RationIngredDB.Ration = "+RationIngredDB.Ration);
                        -- WriteLn(2,"g_CurrentRation       = "+g_CurrentRation);
                        if RationIngredDB.Ingred=g_CurIngredient then
                          g_WaitSp:=0;
                          -- WriteLn(2,"== Ingredient Match Found ==");
                          exit;
                        end if;
                      end if;
                      if RationIngredDB.GetNext<>SysOk then 
                        SetLabelText(Lbl3S2,"** Not Found *# "+IntegerToString(g_WaitSp,0));
                        SetLabelText(Lbl4S2,"Ing: "+g_CurIngredient);
                        SetLabelText(Lbl5S2,"Ration: "+g_CurrentRation);
                        -- WriteLn(2,"** Ingredient Match NOT Found **");
                        -- WriteLn(2,"Ingredient = "+g_CurIngredient);
                        -- WriteLn(2,"Ration     = "+g_CurrentRation);
                        g_SubLevel:=2;
                        if g_WaitSp=0 then
                          g_WaitSp:=2;  -- Flag for Error on Ingredient Load
                        else
                          g_WaitSp:=g_WaitSp+1;  -- g_WaitSp = One more than the number of fails 
                        end if;
                        -- WriteLn(2,"Wait Sp = "+IntegerToString(g_WaitSp,0));
                        SetSoftkeyText(1,"");
                        SetSoftkeyText(2,"Re-Try");
                        SetSoftkeyText(3,"");
                        SetSoftkeyText(4,"Cancel");
                        SetSoftkeyText(5,"");
                        exit;
                      end if;          
                   end loop;
                   
                   if g_WaitSp=0 then
                     
                     GetNet(scale1,Primary,Net);
                   
                     -- WriteLn(2,"Net "+IntegerToString(Net,0));
                     -- WriteLn(2,"RationIngredDB.Target"+IntegerToString(RationIngredDB.Target,0));
                     -- WriteLn(2,"RationIngredDB.Min"+IntegerToString(RationIngredDB.Min,0));
                     -- WriteLn(2,"RationIngredDB.Max"+IntegerToString(RationIngredDB.Max,0));
     
      
                     Factor:=GetFactor;
                     Min:=(RationIngredDB.Target*Factor)- RationIngredDB.Min ;
                     Max:=(RationIngredDB.Target*Factor)+ RationIngredDB.Max ;  
          
                   end if;  -- g_WaitSp 0 Statement     
                   
                 end if; -- g_WaitSp 0 or 2 if statement
          
                 if Net> Max and g_WaitSp=0 then  -- Only execute Over Limit Text ONCE!
                         
                   -- WriteLn(2,"Net is Greater Than Max");    
                   SetLabelText(Lbl3S2,"Error");
                   SetLabelText(Lbl4S2,"Weight Above Max");
                   SetLabelText(Lbl5S2,"Target := "+IntegerToString(RationIngredDB.Target*Factor,0)+" Max="+IntegerToString(Max,0));
                   g_SubLevel:=2;
                   SetSoftkeyText(1,"");
                   SetSoftkeyText(2,"Resume");
                   SetSoftkeyText(3,"");
                   SetSoftkeyText(4,"Cancel");
                   SetSoftkeyText(5,"");
                   g_WaitSp:=1;
                         
                 else
                   
                   if g_WaitSp=0 then    -- Only execute correct weight routine once.  
                     
                     -- WriteLn(2,"Wait within limit, should tare scale next");
                     SetTimerMode(1,TimerOneShot);
                     SetTimer(1,50);
                     StartTimer(1);
                     StoreLoad(0);
                     TareScale;
                     
                   end if;  
                   g_WaitSp:=1;        -- Ingredient has finished set variable to flag this
                   SetTimerMode(1,TimerOneShot);
                   SetTimer(1,50);
                   StartTimer(1);
                   if g_SubLevel=1 then
                     
                     SelectScreen(1);
                     SetLabelText(lbl2S1,"Unable to Tare Scale");
                     SetLabelText(lbl3S1,"Batch Paused");
                     SetLabelText(lbl4S1,"Tare Scale before resuming");
                     SetSoftkeyText(1,"");
                     SetSoftkeyText(2,"Resume");
                     SetSoftkeyText(3,"Tare Scale");
                     SetSoftkeyText(4,"Cancel");
                     SetSoftkeyText(5,"");      
                      
                   else
                    
                     -- WriteLn(2,"StartBatch executing...");
                     StartBatch;
                     
                   end if;
                           
                 end if; 
                   
                 SetTimerMode(1,TimerOneShot);
                 SetTimer(1,50);
                 StartTimer(1); 
                        
                 
                 
              elsif CurrentSp=42 then
              
                 g_Level:=9;
                 g_WaitSp:=0;      -- Reset g_WaitSp to 0 when batch finishes.
                 SetTimerMode(1,TimerOneShot);
                 SetTimer(1,50);
                 StartTimer(1);
                     
              end if;
                  
          end if;
             
       end if;   
    elsif g_Level=9 then       
    
      ResetBatch;
      ClearTare(scale1);                                        
      GetGross(scale1,Primary,gross);
      g_CurrentTarget:=Gross;
      SetLabelText(Lbl2S2,g_CurrentRation);
      SetLabelText(Lbl3S2,"");
      SetLabelText(Lbl4S2,"Ready To Discharge");
      SetLabelText(Lbl5S2,"To Truck");
      g_SubLevel:=0;
      SetSoftkeyText(1,"");
      SetSoftkeyText(2,"");
      SetSoftkeyText(3,"Unload To Truck");
      SetSoftkeyText(4,"");
      SetSoftkeyText(5,"");
    elsif g_Level=10 then
      g_Level:=8;
      SelectScreen(1);
      g_SubLevel:=1;                
      PauseBatch;
      SetLabelText(lbl2S1,"");
      SetLabelText(lbl3S1,"Batch Paused");
      SetLabelText(lbl4S1,"");
      SetSoftkeyText(1,"");
      SetSoftkeyText(2,"Resume");
      SetSoftkeyText(3,"");
      SetSoftkeyText(4,"Cancel");
      SetSoftkeyText(5,"");                         
    end if;     
      
    return;

end;  

procedure PromptForBatch;
--Declaration Section

begin
      ClearTare(1);
      DisableSP(50); --Unload Setpoint
      
      g_CurrentSp:=0;
      g_CurrentTarget:=0;        
      g_SubLevel:=0;
      g_Level:=1;
      ResetBatch;

    UpdateDisplay;
    return;

end;
  




---Used by the Rotary Encoder on the front of the panel to select an Item 

 procedure SetCount;
 --Declaration Section
Bit1 : integer;
Bit2 : integer;
CurBitStatus : integer;

 begin    
     GetDigin(0,2,Bit1);
     GetDigin(0,3,Bit2);
     if Bit1=0 and Bit2=0 then
        CurBitStatus:=0;
     elsif Bit1=1 and Bit2=0 then
        CurBitStatus:=1;
     elsif Bit1=1 and Bit2=1 then
        CurBitStatus:=2;
     elsif Bit1=0 and Bit2=1 then
        CurBitStatus:=3;
     end if; 
     
     if g_BitStatus=0 and CurBitStatus=3 then
        g_Count:=g_Count-1;
     elsif g_BitStatus=3 and CurBitStatus=0 then
        g_Count:=g_Count+1;
     elsif g_BitStatus>CurBitStatus then
        g_Count:=g_Count-1;
     else
        g_Count:=g_Count+1;
     end if;     
     
     
--     if g_Count>g_CountMax then
--        g_Count:=0;                        
--     end if;                       
--     
--     if g_Count<0 then
--        g_Count:=g_CountMax;                        
--     end if;   
     g_BitStatus:=CurBitStatus;  
     if g_Level=1 then 
       g_CurrentTarget:=0;
     end if;  
     UpdateDisplay;
     --SetLabelText(lbl2S1,"Count:= "+IntegerToString(g_Count,0));
    return;

 end;

