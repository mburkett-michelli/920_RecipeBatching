handler Timer2Trip;--Update BarGraph
--Declaration Section
Net : real;       
Gross : real;
CorrectedWeight : real;
CurrentSp : integer;              
BLevel : integer;
BLevel2 : integer;
begin   

    GetGross(Scale1,Primary,gross);
    CorrectedWeight:=Gross - g_StartingWeight;

    if g_Level=8 then

        GetNet(Scale1,Primary,Net); 
        
        if g_CurSpValue>0 then
            BLevel:=(Net/g_CurSpValue)*100;
        else                            
            BLevel:=0;
        end if;
        
        SetLabelText(lbl14s2,RealToString(CorrectedWeight,5,0));
        SetLabelText(lbl9s2,RealToString(g_ScaleRationTargetWeight,5,0));
                
    elsif g_Level=9 then
      
        if g_CurrentTarget>0 then
            BLevel:=(Gross/g_CurrentTarget)*100;
        else
            BLevel:=0;
        end if;        
    
    end if;

--  Commented Out Section is for a second Bargraph if customer wants one.
--    
--    if g_ScaleRationTargetWeight>0 then
--      
--      BLevel2:=(Gross/g_ScaleRationTargetWeight)*100;
--
--    else
--    
--      BLevel2:=0;
--    
--    end if;        

    if BLevel>100 then 
       BLevel:=100;
    end if;
--    if BLevel2>100 then 
--       BLevel2:=100;
--    end if;              
    SetBargraphLevel(Bar1S2,BLevel);
--    SetBargraphLevel(Bar2S2,BLevel2);
    return;

end;



