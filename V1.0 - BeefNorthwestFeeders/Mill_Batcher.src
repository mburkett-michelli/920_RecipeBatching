--                       Batching Stuff

------------------------------------------------------------------------------- 
 
 --Set the Preact for the specified Ingredient based on the target Weight. 
 --***THE TARGET WEIGHT IS THE GROSS WEIGHT***  The Target weight of the setpoint is the net weight
 function Preact(Target:real; Ingredient : string) : real;
--Declaration Section                                  
X1:real;
Y1:real;
X2:real;
Y2:real;
Slope : real;
B : real;    
Retval:real;            
Setup : SetupDatabase;
Ingred : IngredDatabase;

begin

    Setup.GetFirst;
    Ingred.Name:=Ingredient;
    if Ingred.FindFirst(Ingred_Name)=SysOk then
        X1:=0;
        Y1:=ingred.Low_Act;
        
      --  X2:=Setup.MaxLoad;
        X2:=160;
      --  Y2:=ingred.High_Act+Setup.MaxLoad;
      
        Y2:=ingred.High_Act;
        if X2/Y2 < 2 then
          X2:=320;
        end if;
        Slope:=(Y2-Y1)/(X2-X1);  -- Find the slope
        
      --   ** Sean's Slope Routine  **
      --  if X1-X2=0 then
      --     RetVal:=0;
      --  else
        
        
        --   Slope:=(Y1-Y2)/(X1-X2);
        --   B:=Y1-(Slope*X1);
        --   if Slope<>0 then
        --     Retval:=Target-((Target/Slope)-B);
        --   else
        --     RetVal:=0;
        --     
        --   end if;   
           
      --  end if;

      if Target>X2 or Y1=Y2 then
      
        Retval:=Y2;
      
      else 
        
         Retval:=(Target*Slope)+Y1;
        
      end if;
      
      if Target < Retval+10 then     -- If the target weight is within 5 of returned then return half the target
        
        Retval:=Target/2;
        
      end if;
      
    else
        Retval:=0;
    end if;                             
    
    if RetVal<0 then 
      Retval:=0;
    end if;
     -- WriteLn(2,"Ingredient - "+Ingredient);
     -- WriteLn(2,"Target = "+IntegerToString(Target,0));
     -- WriteLn(2,"Slow Target = "+IntegerToString(RetVal,0));
       
    return (Retval);

end;
 
 

procedure SetBatch;
--Declaration Section
Setpt : integer;
SpValue : real;
R_Names : R_NamesDatabase;
R_Ingred : R_IngredDatabase;
Ingred : IngredDatabase;               
Loads : LoadsDatabase;  
Found : integer;
index : integer;    
GrossTagret : integer;
CurGross : real;
Bit : integer;        
CurPreact : real;                                  
Factor : real;
SetupDB :SetupDatabase;         
Gross : real;
fast : real;             -- Value for fast setpoint to be satisfied at
cutoff : real;           -- Value for slow setpoint to be satisfied at

begin

    g_ScaleRationTargetWeight:=0;  -- Set Total Scale Dispensed weight to 0 
    GetGross(Scale1,Primary,CurGross);
    GetDigin(0,1,Bit);
    if Bit=1 then
       DisplayStatus("E-Stop Activated");
    elsif CurGross<50 and CurGross >-50 then
        --  Batch Start Selected, Display message to inform them that process has started
        SelectScreen(1);
        SetLabelText(Lbl2S1,"");
        SetLabelText(Lbl3S1,"Initializing Batch");
        SetLabelText(Lbl4S1,"");
        DisplayStatus("Please Wait...");   
        SetSoftkeyText(1,"");
        SetSoftkeyText(2,""); 
        SetSoftkeyText(3,"");
        SetSoftkeyText(4,"");
        SetSoftkeyText(5,"");
        
        GrossTagret:=CurGross;
        R_Names.Name:=g_CurrentRation;
        R_Names.FindFirst(R_Names_Name);
        
        Ingred.GetFirst; 
        
        SetupDB.GetFirst;
        if R_Names.Total > 0 then
           Factor:=g_CurrentTarget/R_Names.Total;
        else
           Factor :=1;    
        end if;
        
        for index:= 1 to 8
        loop
          g_IngredNames[index]:="";
          g_SPValues[Index]:=0;
          g_SpPreact[Index]:=0;
          g_SpMin[index]:=0;
          g_SpMax[index]:=0;
          R_Ingred.GetFirst;
          GrossTagret:=0;

          loop              
            if R_Ingred.Ration=g_CurrentRation and R_Ingred.Ingred = Ingred.Name then
              g_IngredNames[index]:=R_Ingred.Ingred;
              
        
              g_SPValues[index]:=R_Ingred.Target*Factor;
              
              GrossTagret:=g_SPValues[index];
              
              g_ScaleRationTargetWeight:=g_ScaleRationTargetWeight + GrossTagret;
              
              CurPreact:=Preact(GrossTagret,Ingred.Name);
              
              g_SpPreact[index]:=CurPreact;
              
              g_SpMin[index]:=R_Ingred.Min;
              g_SpMax[index]:=R_Ingred.Max;
              exit;
            else            
              if R_Ingred.GetNext<>SysOk then
                exit;
              end if;  
            end if;     
          end loop;
          Ingred.GetNext;
        end loop;        
        
        --   ** Use the section to trouble shoot if your ingredients are not correct  **
        --
        -- WriteLn(2,"Total Weight Dispensed for Ration ="+RealToString(g_ScaleRationTargetWeight,4,0));
        
        -- for index:= 1 to 8
        -- 
        -- loop                    
        --   
          -- if g_IngredNames[index]<>"" then
          --    
          --   WriteLn(2,"Ingredients For Ration  "+g_CurrentRation);
          --   WriteLn(2,"Index "+IntegerToString(index,0)+" Ingredient "+g_IngredNames[index]);
          --   WriteLn(2,"     SPValue "+IntegerToString(g_SPValues[Index],0));
          --   WriteLn(2,"     SPPreact "+IntegerToString(g_SpPreact[Index],0));
          --   WriteLn(2,"     SPMin "+IntegerToString(g_SpMin[index],0));
          --   WriteLn(2,"     SPMax "+IntegerToString(g_SpMax[index],0));
          --   WriteLn(2,"  ");
          --   WriteLn(2,"----------------------------------");
          --
          -- end if;
          --  
        -- end loop;        
        
        
        for Setpt := 3 to 38 step 5
        loop
          index:=((Setpt-3)/5)+1;
          -- WriteLn(2,"index"+IntegerToString(index,0)); 
          if g_SPValues[index]>0 then
            EnableSP(Setpt);
            EnableSP(Setpt+1);
            EnableSP(Setpt+2);          
            EnableSP(Setpt+3);          
            EnableSP(Setpt+4);          
            
            fast:=g_SPValues[index]-g_SpPreact[index];
            cutoff:=g_SPValues[index]-g_SpMin[index];
            
            if fast > cutoff then   -- Catch if the fast setpoint is greater than the cutoff on slow sp
              
              cutoff:=g_SPValues[index];
              
            end if;
            
            SetSPValue(Setpt,fast);
            SetSPValue(Setpt+2,cutoff);
            SetSPPreact(Setpt,0);
            SetSPPreact(Setpt+1,0);
            
          else                   
          
            DisableSP(Setpt);
            DisableSP(Setpt+1);
            DisableSP(Setpt+2);
            DisableSP(Setpt+3);
            DisableSP(Setpt+4);            
          
          end if;  
        
        end loop; 
        Found:=0;
        g_Load:=1;    
        if Loads.GetFirst=SysOk then
           loop     
              if Date$(Loads.Date)=Date$(SystemTime) then
                 if g_Load = Loads.Load then
                   Found :=1;
                 end if; 
              end if; 
              if Loads.GetNext<>SysOk or Found=1 then
                if Found =0 then
                  exit;
                else 
                  g_Load:=g_Load+1;
                  Found :=0; 
                  Loads.GetFirst; 
                end if;   
              end if;  
           end loop;
        end if;   
        GetGross(Scale1,Primary,Gross);
        if Gross <=0 then
          ZeroScale(scale1);
        else
        
          g_StartingWeight:=Gross;
          AcquireTare(Scale1);    
          
        end if;  

        StartBatch;
        g_Level:=8;           
        UpdateDisplay;
        
    else
        SelectScreen(1);
        SetLabelText(Lbl2S1,"");
        SetLabelText(Lbl3S1,"Scale Not At Zero");
        SetLabelText(Lbl4S1,"");
        DisplayStatus("Zero Scale To Continue");   
        SetSoftkeyText(1,"");
        SetSoftkeyText(2,""); 
        SetSoftkeyText(3,"Start Batch");
        SetSoftkeyText(4,"");
        SetSoftkeyText(5,"Cancel");
    end if;        
    return;

end;




-------------------------------------------------------------------------------

--                   End Of Batching Stuff

------------------------------------------------------------------------------- 








  -- End of functions and procedures.
  ----------------------------------------------------------------------------






  ----------------------------------------------------------------------------
  -- Begin event handler definitions here.                                    
  
handler Cmd1Handler;
--Declaration Section
LoadsDB : LoadsDatabase;
begin
   if LoadsDB.GetFirst<>SysOk then
      WriteLn(EventPort,"EMPTY DATABASE");
   else
     WriteLn(EventPort,"BEGIN DATABASE");
     loop
         WriteLn(EventPort,Date$(LoadsDB.Date)+" "+Time$(LoadsDB.Date)+","+
                          IntegerToString(LoadsDB.Load,0)+","+
                          LoadsDB.Ingred+","+
                          IntegerToString(LoadsDB.Target,0)+","+
                          IntegerToString(LoadsDB.Actual,0)+","+
                          LoadsDB.Ration+","+
                          IntegerToString(LoadsDB.Sent,0)+","+
                          IntegerToString(LoadsDB.Status,0));
        LoadsDB.Sent:=1;
        LoadsDB.Update;
        if LoadsDB.GetNext<>SysOk then
          exit;
        end if;  
        
     end loop;
     WriteLn(EventPort,"END DATABASE");
   end if;    
   return;

end;         

handler Cmd2Handler;
--Declaration Section
Cnt : integer;          
LoadsDB : LoadsDatabase;
begin                   
    Cnt:=0;
    if LoadsDB.GetFirst<>SysOk then
      WriteLn(EventPort,"EMPTY DATABASE");
    else
      WriteLn(EventPort,"CLEARING DATABASE");
      loop
        if LoadsDB.Sent=1 then
           LoadsDB.Delete;
        end if;
        if LoadsDB.GetNext<>SysOk then
           exit;
        end if;  
      end loop;
      WriteLn(EventPort,"DATABASE CLEARED");
    end if;  
    return;

end;


handler Navupkeypressed;
--Declaration Section

begin
    g_Count:=g_Count-1;
    if g_Level=1 then 
       g_CurrentTarget:=0;
    end if;  
    
    UpdateDisplay;
    return;

end;      


handler Navdownkeypressed;
--Declaration Section

begin
    g_Count:=g_Count+1;   
    if g_Level=1 then 
       g_CurrentTarget:=0;
    end if;  

    UpdateDisplay;

    return;

end;



  
handler User1Keypressed;
--Declaration Section
R_IngredDB :R_IngredDatabase;  
Bit : integer;
begin    
    GetDigin(0,1,Bit);
    if g_Level=1 and Bit=0 then          
       g_SubLevel:=1;
      
       SelectScreen(10);
       SetLabelText(Lbl1S10,"Enter Total Load Weight");
       SetLabelText(Lbl2S10,"For Ration");
       SetLabelText(Lbl3S10,g_CurrentRation);
       SetLabelText(Lbl4S10,"Current Value");
       SetLabelText(Lbl5S10,IntegerToString(g_CurrentTarget,0));
       PromptUser("Total");
       DisableHandlers;                             
    elsif g_Level=2 and g_SubLevel=0 and g_CurrentRation <>"" then
      g_SubLevel:=1;                              
      UpdateDisplay;         
    elsif g_Level=2 and g_SubLevel=1 then 
      g_SubLevel:=0;
      UpdateDisplay;  
    elsif g_Level=3 then --Select Ration To Edit
      g_Level:=2;    
      g_Count:=0;
      UpdateDisplay;  
    elsif g_Level=4 then  
      g_SubLevel:=1;
      SelectScreen(10);
      SetLabelText(Lbl1S10,"");
      SetLabelText(Lbl2S10,"Edit Ingredient Name");
      SetLabelText(Lbl3S10,"Current Name");
      SetLabelText(Lbl4S10,g_CurIngredient);
      SetLabelText(Lbl5S10,"");
      PromptUser("Name");
      DisableHandlers;   
    elsif g_Level=5 and g_CurIngredient<>"" then  --Delete Ingredient from ration
         
      R_IngredDB.GetFirst;
      loop
        if R_IngredDB.Ingred=g_CurIngredient and R_IngredDB.Ration=g_CurrentRation then
          R_IngredDB.Delete;
          exit;
        end if;
        if R_IngredDb.GetNext<>SysOk then 
          exit;
        end if;      
      end loop;
      g_Count:=g_Count-1;
      UpdateDisplay;
      
    elsif g_Level=7 then
      SelectScreen(10);
      R_IngredDB.GetFirst;
      loop
        if R_IngredDB.Ingred=g_CurIngredient and R_IngredDB.Ration=g_CurrentRation then
          exit;
        end if;
        if R_IngredDb.GetNext<>SysOk then 
          exit;
        end if;      
      end loop;  
      
      SetLabelText(Lbl1S10,"Set Target For");
      SetLabelText(Lbl2S10,"Ration "+R_IngredDB.Ration);
      SetLabelText(Lbl3S10,R_IngredDB.Ingred); 
      SetLabelText(Lbl4S10,"Current Target");  
      SetLabelText(Lbl5S10,IntegerToString(R_IngredDB.Target,0)); 
      g_SubLevel:=1;
      PromptUser("Target");
      
    elsif g_Level=8 and g_SubLevel=0 then
      SelectScreen(1);
      g_SubLevel:=1;                
      PauseBatch;
      SetLabelText(lbl2S1,"");
      SetLabelText(lbl3S1,"Batch Paused");
      SetLabelText(lbl4S1,"");
      SetSoftkeyText(1,"");
      SetSoftkeyText(2,"Resume");
      SetSoftkeyText(3,"");
      SetSoftkeyText(4,"Cancel");
      SetSoftkeyText(5,""); 
    elsif g_Level=9 then
      PromptForBatch;
    end if;
       

    return;

end;

  
handler User2Keypressed;
--Declaration Section
IngredDB : IngredDatabase;    
R_IngredDB : R_IngredDatabase;
begin
    if g_Level=2 and g_Count<25 then
       g_SubLevel:=2;   
       SetLabelText(lbl1S10,"New Ration");
       SetLabelText(lbl2S10,"Key In Ration");
       SetLabelText(lbl3S10,"Name");
       SetLabelText(lbl4S10,"Then Press Enter");                        
       SetLabelText(lbl5S10,"");   
       PromptUser("Name");
       DisableHandlers; 
     elsif g_Level=3 then --Select Ingred To Edit
       g_Level:=4;    
       g_Count:=0;        
       UpdateDisplay;
     elsif g_Level=4 and g_CurIngredient<>"" then
        g_SubLevel:=2;
        IngredDB.Name:=g_CurIngredient;
        IngredDb.FindFirst(Ingred_Name);
        SelectScreen(10);
        SetLabelText(Lbl1S10,"");
        SetLabelText(Lbl2S10,"Edit High Preact For");
        SetLabelText(Lbl3S10,g_CurIngredient);
        SetLabelText(Lbl4S10,"Current Value");
        SetLabelText(Lbl5S10,RealToString(IngredDB.High_Act,0,1));
        PromptUser("High Preact");
        DisableHandlers;
     elsif g_Level=5 and g_RecordCount<8 then
        g_Count:=0;
        g_Level:=6;
        UpdateDisplay;   
    elsif g_Level=7 then
      SelectScreen(10);
      R_IngredDB.GetFirst;
      loop
        if R_IngredDB.Ingred=g_CurIngredient and R_IngredDB.Ration=g_CurrentRation then
          exit;
        end if;
        if R_IngredDb.GetNext<>SysOk then 
          exit;
        end if;      
      end loop;  
      
      SetLabelText(Lbl1S10,"Set Early Cutoff Amount For");
      SetLabelText(Lbl2S10,"Ration "+R_IngredDB.Ration);
      SetLabelText(Lbl3S10,R_IngredDB.Ingred); 
      SetLabelText(Lbl4S10,"Current Value");  
      SetLabelText(Lbl5S10,IntegerToString(R_IngredDB.Min,0)); 
      g_SubLevel:=2;
      PromptUser("Cutoff");        
     elsif g_Level=8 and g_SubLevel=1 then
       StartBatch;
       g_SubLevel:=0;
       UpdateDisplay;
     elsif g_Level=8 and g_SubLevel=2 then
       SetTimerMode(1,TimerOneShot);
       SetTimer(1,50);
       StartTimer(1);
       StoreLoad(0);     
       TareScale;
       SetTimerMode(1,TimerOneShot);
       SetTimer(1,50);
       StartTimer(1);
       StartBatch;
       g_SubLevel:=0;
       UpdateDisplay;
             
     end if;     
     
    return;

end;

handler User3Keypressed;
--Declaration Section
IngredDB : IngredDatabase; 
R_IngredDB : R_IngredDatabase;
RatIng_Ration : stringarray;
RatIng_Ingredient : stringarray;
RatIng_Target : realarray;
RatIng_Min : realarray;
RatIng_Max : realarray;
Index : integer;
Ingredient_Count : integer;
Count : integer;

begin
    if g_Level=0 then
      g_Level:=1; --Select Ration              
      UpdateDisplay;     
    elsif g_Level=1 then     
      SetLabelText(lbl1S10,"");
      SetLabelText(lbl2S10,"");
      SetLabelText(lbl3S10,"Loading");
      SetLabelText(lbl4S10,"Ration");
      SetLabelText(lbl5S10,"Wait");
      SetSoftkeyText(3,"");
      SetBatch;  
    elsif g_Level=2 then -- Selected The Ration To Edit
      g_Level:=5;
      UpdateDisplay;  
    elsif g_Level=3 then
      KeyPress(TimeDateKey);   
    elsif g_Level=4  and g_CurIngredient<>"" then
      g_SubLevel:=3;
      IngredDB.Name:=g_CurIngredient;
      IngredDb.FindFirst(Ingred_Name);
      SelectScreen(10);
      SetLabelText(Lbl1S10,"");
      SetLabelText(Lbl2S10,"Edit Low Preact For");
      SetLabelText(Lbl3S10,g_CurIngredient);
      SetLabelText(Lbl4S10,"Current Value");
      SetLabelText(Lbl5S10,RealToString(IngredDB.Low_Act,0,1));
      PromptUser("Low Preact");
      DisableHandlers;    
    elsif g_Level=5 and g_CurIngredient<>"" then
      g_Level:=7;
      UpdateDisplay;     

    elsif g_Level=6 then
      
      --  First save the new ingredient to the database
      R_IngredDB.Ration:=g_CurrentRation;
      R_IngredDB.Ingred:=g_CurIngredient;
      R_IngredDB.Target:=0;
      R_IngredDB.Min:=0;
      R_IngredDB.Max:=0;
      R_IngredDB.Add;
      WriteLn(2,g_CurIngredient+" Ingredient Saved to DB");
      --  Second Load in all the records for the ration into an array
      R_IngredDB.GetFirst;
      Index:=0;
      loop
        
        if R_IngredDB.Ration=g_CurrentRation then
          
          Index:=Index+1;
          RatIng_Ration[Index]:=R_IngredDB.Ration;
          RatIng_Ingredient[Index]:=R_IngredDB.Ingred;
          RatIng_Target[Index]:=R_IngredDB.Target;
          RatIng_Min[Index]:=R_IngredDB.Min;
          RatIng_Max[Index]:=R_IngredDB.Max;
          
        end if;
        
        if R_IngredDb.GetNext<>SysOk or Index=8 then
        
          WriteLn(2,"Number of Ingredients for Ration: "+g_CurrentRation);
          WriteLn(2,"--> "+IntegerToString(index,0)); 
          exit;
        end if;      
      
      end loop;
  
      
      -- Third Erase the ration from the database
      R_IngredDB.GetFirst;
      loop
        
        if R_IngredDB.Ration=g_CurrentRation then
          
          WriteLn(2,R_IngredDB.Ingred+" deleted.");
          R_IngredDB.Delete;
          
        end if;
        
        if R_IngredDb.GetNext<>SysOk then 
          exit;
        end if;      
        
      end loop;
                                                                      
      -- Fourth Save all the ingredients for the ration to the database.
      
      IngredDB.GetFirst;
      Count:=0;
      
      while Count<Index+1  
      loop
       
        -- This loop goes through ingredients one at a time in order  
        if IngredDB.Name<>"" then
        
          for Ingredient_Count:=1 to index  --  This loops through the ingredients for the ration
          loop
            
            WriteLn(2,IngredDb.Name+" ------- "+RatIng_Ingredient[Ingredient_Count]);

            --  If a match is found add it to the DB then start on the next ingredient
            if RatIng_Ingredient[Ingredient_Count] = IngredDB.Name then
                        
              R_IngredDB.Ration:=RatIng_Ration[Ingredient_Count];
              R_IngredDB.Ingred:=RatIng_Ingredient[Ingredient_Count];
              R_IngredDB.Target:=RatIng_Target[Ingredient_Count];
              R_IngredDB.Min:=RatIng_Min[Ingredient_Count];
              R_IngredDB.Max:=RatIng_Max[Ingredient_Count];
              R_IngredDB.Add;
              WriteLn(2,RatIng_Ingredient[Ingredient_Count]+" Added to DB");
              Ingredient_Count:=index;
              Count:=Count+1;
              
            end if;
          
          end loop;  
        
        end if;
            
        if IngredDb.GetNext<>SysOk then 
          
          Count:=Index+1;                                                                     
          
        end if;
      
      end loop;
      
      g_level:=5;
      g_Count:=0;
      WriteLn(2,"Updating Display.");
      UpdateDisplay;   
 
    elsif g_Level=7 then
      SelectScreen(10);
      R_IngredDB.GetFirst;
      loop
        if R_IngredDB.Ingred=g_CurIngredient and R_IngredDB.Ration=g_CurrentRation then
          exit;
        end if;
        if R_IngredDb.GetNext<>SysOk then 
          exit;
        end if;      
      end loop;  
      
      SetLabelText(Lbl1S10,"Set Maximum Acceptable lbs For");
      SetLabelText(Lbl2S10,"Ration "+R_IngredDB.Ration);
      SetLabelText(Lbl3S10,R_IngredDB.Ingred); 
      SetLabelText(Lbl4S10,"Current Value");  
      SetLabelText(Lbl5S10,IntegerToString(R_IngredDB.Max,0)); 
      g_SubLevel:=3;
      PromptUser("Max");
    elsif g_Level=8 and g_SubLevel=1 and g_WaitSp=1 then
      if AcquireTare(Scale1)=SysOk then
        SetLabelText(lbl2S1,"Tare Successful");
        SetLabelText(lbl3S1,"Batch Paused");
        SetLabelText(lbl4S1,"Please Press Resume");
      end if;
    elsif g_Level=9 and g_SubLevel=0 then
      UnloadToTruck;                
      g_Sublevel:=3;
    elsif g_Level=9 and g_SubLevel=3 then
      SetLabelText(Lbl3S2,"***Paused***");
      SetLabelText(Lbl4S2,"Unloading");
      SetLabelText(Lbl5S2,"To Truck");
      g_SubLevel:=0;
      SetSoftkeyText(1,"Cancel");
      SetSoftkeyText(2,"");
      SetSoftkeyText(3,"Restart");
      SetSoftkeyText(4,"");
      SetSoftkeyText(5,"");   
      DisableSP(50);                        
    end if;  
    return;

end;

handler User4Keypressed;
--Declaration Section
RationNamesDB :R_NamesDatabase;
begin
    if g_Level=5 then     
      RationNamesDB.Name:= g_CurrentRation;
      RationNamesDB.FindFirst(R_Names_Name);
      SelectScreen(6);
      g_SubLevel:=4;          
      SetLabelText(Lbl6S6,"Current total weight for Ration : "+RationNamesDB.Name);
      SetLabelText(Lbl7S6,IntegerToString(RationNamesDB.Total,0)+" lbs");
      PromptUser("Total Weight");
      DisableHandlers; 
    elsif g_Level=8 and g_SubLevel=1 then
       ResetBatch;
       g_SubLevel:=0;
       g_Level:=0;
       UpdateDisplay;    
    elsif g_Level=8 and g_SubLevel=2 then
       ResetBatch;
       StoreLoad(1);           
       g_SubLevel:=0;
       g_Level:=0;
       UpdateDisplay;    
       
    end if; 
    return;

end;



handler User5Keypressed;
--Declaration Section
RNamesDB :R_NamesDatabase;
RIngredDB : R_IngredDatabase;
begin
    if g_Level=0 then
       g_Level:=3;
       g_CurrentTarget:=0;   
    elsif g_Level=1 and g_SubLevel=0 then
      g_Count:=0; 
      g_Level:=0;
    elsif g_Level=2 and g_SubLevel=0 then
      g_Count:=0; 
      g_Level:=3;
    elsif g_Level=1 or g_Level=2 and g_SubLevel=1 then 
       RNamesDB.Name:=g_CurrentRation;
       RNamesDB.FindFirst(R_Names_Name);
       RNamesDB.Delete;
       RIngredDB.Ration:=g_CurrentRation;
       loop
           if RIngredDB.FindFirst(R_Ingred_Ration)<>SysOk then
             exit;
           end if;
           RIngredDB.Delete;  
       end loop;
       g_SubLevel:=0;                    
    elsif g_Level=3 then
        g_Level:=0;     
        g_Count:=0;  
    elsif g_Level=4 then
        g_Level:=3;
        g_Count:=0;
    elsif g_Level=5 then
        g_Level:=3;
        g_Count:=0;
    elsif g_Level=6 or g_Level=7 then
       g_Level:=5;
       g_Count:=0;       
    end if;
         
    
    UpdateDisplay;    
    return;

end;






 handler Numerickeypressed;
----Declaration Section

begin

    return;

end;



 handler Userentry;
--Declaration Section
UserString :string;
UserReal : real;
EntryString : string; 
R_IngredDB : R_IngredDatabase;
RationNamesDB : R_NamesDatabase; 
IngredDB :IngredDatabase;  
Total : integer;  
OriginalName : string;
index : integer;   
Ok : integer;
begin                              
    UserString := GetEntry;
    ClosePrompt;          
    EnableHandelers;
    UserReal:=StringToReal(UserString);
    if EventKey = EnterKey   then          
      if g_Level=2 and g_SubLevel=2 then
        if UserString<>""then
          RationNamesDB.Name:=UserString;
          if RationNamesDB.FindFirst(R_Names_Name)=SysOk then
            DisplayStatus("Name Already Used");        
          else
            RationNamesDB.Name:=UserString;
            RationNamesDB.Add;         
            g_CurrentRation:=UserString;
            RationNamesDb.GetFirst;
            g_Count:=0;
            if RationNamesDb.Name<>g_CurrentRation then
              loop
                g_Count:=g_Count+1;
                RationNamesDb.GetNext;
                if RationNamesDb.Name=g_CurrentRation then
                  exit;
                end if;    
                
              end loop;
            end if;
          end if;   
        end if;             
        
--Edit total Target for Load                   
        
      elsif g_Level=1 and g_SubLevel=1 then
        if UserReal>0 then
          RationNamesDB.Name:=g_CurrentRation;
          RationNamesDB.FindFirst(R_Names_Name);
          if UserReal>RationNamesDB.Total then
            DisplayStatus("Cannot Be > "+IntegerToString(RationNamesDB.Total,0));
          else
            g_CurrentTarget:=UserReal;    
          end if;  
          
        end if;                           
--Edit Ingredient Name           
      elsif g_Level=4 and g_SubLevel=1 then    
        if UserString<>"" then 
          Ok:=0;
          for index:= 0 to 7
          loop
            if index=0 then 
              IngredDB.GetFirst;
            else
              IngredDB.GetNext; 
            end if;
            if g_Count<>index and UCase$(ingredDB.Name)=UCase$(UserString) then
              DisplayStatus("Name Already Used");
              OK:=1;
              exit;
            end if;
          end loop;   
          
          
          
          if Ok=0 then
            for index:= 0 to 7
              loop
              if index=0 then 
                IngredDB.GetFirst;
              else
                IngredDB.GetNext; 
              end if;
              if g_Count=index then
                OriginalName:=IngredDB.Name;
                IngredDB.Name:=UserString;   
                INgredDB.Update;
                exit;
              end if;
            end loop; 
            
            if R_IngredDB.GetFirst=SysOk then
               loop
                WriteLn(2,R_IngredDB.Ingred+"  "+OriginalName);
               if R_IngredDB.Ingred=OriginalName and OriginalName<>"" then
                 R_IngredDB.Ingred:=UserString; 
                 R_IngredDB.Update;  
               end if;   
               if R_IngredDB.GetNext<>SysOk then
                 exit;
               end if;  
               end loop;
            end if;
              
          end if;
        end if;                             
        
        
        
--Edit Ingredient High Preact
      elsif g_Level=4 and g_SubLevel=2 then    
        if UserString<>"" then 
          IngredDB.Name:=g_CurIngredient;
          IngredDb.FindFirst(Ingred_Name);        
          IngredDB.High_Act:=UserReal;
          IngredDB.Update;
        end if;
        
--Edit Ingredient Low Preact
      elsif g_Level=4 and g_SubLevel=3 then    
        if UserString<>"" then 
          IngredDB.Name:=g_CurIngredient;
          IngredDb.FindFirst(Ingred_Name);        
          IngredDB.Low_Act:=UserReal;
          IngredDB.Update;
        end if;      
        
--Edit Total        
      elsif g_Level=5 and g_SubLevel=4 then            
         WriteLn(2,RealToString(userreal,0,3));
        if UserReal >0 then      
        
          RationNamesDB.Name:= g_CurrentRation;
          RationNamesDB.FindFirst(R_Names_Name);
          RationNamesDB.Total:=UserReal;
          RationNamesDB.Update;
        end if;
      elsif g_Level=7 and g_SubLevel=1 then
          if UserReal>=0 then   
            Total:=0;
            R_IngredDB.GetFirst;
            loop
            if R_IngredDB.Ingred<>g_CurIngredient and R_IngredDB.Ration=g_CurrentRation then
              Total:=Total+R_IngredDB.Target;
            end if;
            if R_IngredDb.GetNext<>SysOk then 
              exit;
            end if;      
            end loop;  
          
          
          
            R_IngredDB.GetFirst;
            loop
            if R_IngredDB.Ingred=g_CurIngredient and R_IngredDB.Ration=g_CurrentRation then
              exit;
            end if;
            if R_IngredDb.GetNext<>SysOk then 
              exit;
            end if;      
            end loop;
            Total:=Total+R_IngredDB.Target;  
            RationNamesDB.Name:=g_CurrentRation;
            RationNamesDB.FindFirst(R_Names_Name);
            if RationNamesDB.Total<Total+UserReal-R_IngredDB.Target then
               DisplayStatus("Cannot exceed Total");
            else
               R_IngredDB.Target:=UserReal;
               R_IngredDB.Update;
            end if;   
               
          end if;    
--Set Early Target Cutoff for Ration ingredient          
     elsif g_Level=7 and g_SubLevel=2 then
          if UserReal>=0 then   
            R_IngredDB.GetFirst;
            loop
            if R_IngredDB.Ingred=g_CurIngredient and R_IngredDB.Ration=g_CurrentRation then
              exit;
            end if;
            if R_IngredDb.GetNext<>SysOk then 
              exit;
            end if;      
            end loop;
            R_IngredDB.Min:=UserReal;
            R_IngredDB.Update;
          end if;

--Set Max Accepatible for Ration ingredient          
     elsif g_Level=7 and g_SubLevel=3 then
          if UserReal>=0 then   
            R_IngredDB.GetFirst;
            loop
            if R_IngredDB.Ingred=g_CurIngredient and R_IngredDB.Ration=g_CurrentRation then
              exit;
            end if;
            if R_IngredDb.GetNext<>SysOk then 
              exit;
            end if;      
            end loop;
            R_IngredDB.Max:=UserReal;
            R_IngredDB.Update;
          end if;

                    
      end if;    
      g_SubLevel:=0;     
      
      
    else
       DisplayStatus("");
    end if;                    
    UpdateDisplay;
    return;
end;    



